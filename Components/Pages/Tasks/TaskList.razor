@page "/tasks"
@inject TaskService TaskService
@inject AuthService AuthService
@inject ProjectService ProjectService
@inject LabelService LabelService
@inject AppState AppState
@inject NavigationManager Nav

<div class="page-header">
    <h1>רשימת משימות</h1>
    <a href="/tasks/create" class="btn btn-primary"><span class="icon icon-plus"></span> משימה חדשה</a>
</div>

@if (myNewTasks.Any())
{
    <div class="new-tasks-alert">
        <div class="new-tasks-header">
            <span class="notification-badge">@myNewTasks.Count</span>
            <h3>משימות חדשות שהוקצו לך</h3>
        </div>
        <div class="new-tasks-list">
            @foreach (var task in myNewTasks)
            {
                <div class="new-task-item">
                    <div class="new-task-info">
                        <span class="new-task-title clickable-row" @onclick="() => GoToTask(task.Id)">@task.Title</span>
                        <span class="new-task-meta">
                            <span class="badge @task.Priority.ToBadgeClass()">@task.Priority.ToHebrew()</span>
                            מאת @task.Creator.FullName
                            @if (task.DueDate.HasValue)
                            {
                                <span> · <span class="icon icon-calendar"></span> @task.DueDate.Value.ToString("dd/MM/yyyy")</span>
                            }
                        </span>
                    </div>
                    <button class="btn btn-primary btn-sm" @onclick="() => TakeTask(task.Id)">
                        <span class="icon icon-rocket"></span> בטיפול שלי
                    </button>
                </div>
            }
        </div>
    </div>
}

<div class="filter-bar">
    <div class="filter-group">
        <label>חיפוש</label>
        <input type="text" @bind="filter.SearchText" @bind:event="oninput" @bind:after="LoadTasks"
               class="form-control" placeholder="חפש לפי כותרת או תיאור..." />
    </div>
    <div class="filter-group">
        <label>סטטוס</label>
        <select @bind="filterStatus" @bind:after="LoadTasks" class="form-control">
            <option value="">הכל</option>
            <option value="New">חדש</option>
            <option value="InProgress">בטיפול</option>
            <option value="Waiting">ממתין</option>
        </select>
    </div>
    <div class="filter-group">
        <label>עדיפות</label>
        <select @bind="filterPriority" @bind:after="LoadTasks" class="form-control">
            <option value="">הכל</option>
            <option value="Low">נמוכה</option>
            <option value="Medium">בינונית</option>
            <option value="High">גבוהה</option>
            <option value="Critical">קריטית</option>
        </select>
    </div>
    <div class="filter-group">
        <label>משויך ל</label>
        <select @bind="filterAssignee" @bind:after="LoadTasks" class="form-control">
            <option value="">הכל</option>
            @foreach (var user in users)
            {
                <option value="@user.Id">@user.FullName</option>
            }
        </select>
    </div>
    <div class="filter-group">
        <label>יוצר</label>
        <select @bind="filterCreator" @bind:after="LoadTasks" class="form-control">
            <option value="">הכל</option>
            @foreach (var user in users)
            {
                <option value="@user.Id">@user.FullName</option>
            }
        </select>
    </div>
    <div class="filter-group">
        <label>פרויקט</label>
        <select @bind="filterProject" @bind:after="LoadTasks" class="form-control">
            <option value="">הכל</option>
            @foreach (var p in projects)
            {
                <option value="@p.Id">@p.Name</option>
            }
        </select>
    </div>
    <div class="filter-group">
        <label>תגית</label>
        <select @bind="filterLabel" @bind:after="ApplyLabelFilter" class="form-control">
            <option value="">הכל</option>
            @foreach (var lbl in allLabels)
            {
                <option value="@lbl.Id">@lbl.Name</option>
            }
        </select>
    </div>
    <div class="filter-group filter-actions">
        <button class="btn btn-secondary" @onclick="ClearFilters">נקה פילטרים</button>
        <button class="btn btn-primary" @onclick="LoadTasks">סנן</button>
    </div>
</div>

<div class="results-count">נמצאו @tasks.Count משימות פעילות</div>

@if (tasks.Any())
{
    <table class="data-table">
        <thead>
            <tr>
                <th>#</th>
                <th>כותרת</th>
                <th>סוג</th>
                <th>פרויקט</th>
                <th>סטטוס</th>
                <th>עדיפות</th>
                <th>משויך ל</th>
                <th>תאריך יעד</th>
                <th>פעולות</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var task in tasks)
            {
                <tr>
                    <td><strong>@task.TaskNumber</strong></td>
                    <td class="task-title-cell clickable-row" @onclick="() => GoToTask(task.Id)">
                        @task.Title
                        @if (task.TaskLabels.Any())
                        {
                            <span class="task-labels-inline">
                                @foreach (var tl in task.TaskLabels)
                                {
                                    <span class="label-chip-mini" style="--label-color: @tl.Label.Color">@tl.Label.Name</span>
                                }
                            </span>
                        }
                        @if (task.ParentTaskId.HasValue)
                        {
                            <span class="subtask-badge" title="תת-משימה"><span class="icon icon-folder"></span></span>
                        }
                        @if (task.SubTasks.Any())
                        {
                            var done = task.SubTasks.Count(s => s.Status == Models.TaskStatus.Done);
                            <span class="subtask-count-badge" title="@done/@task.SubTasks.Count תתי-משימות">@done/@task.SubTasks.Count</span>
                        }
                        @if (task.Comments.Any())
                        {
                            <span class="comment-icon" title="@task.Comments.Count הערות"><span class="icon icon-tasks"></span> @task.Comments.Count</span>
                        }
                    </td>
                    <td><span class="badge type-badge @task.Type.ToBadgeClass()"><span class="icon @task.Type.ToIconClass()"></span> @task.Type.ToHebrew()</span></td>
                    <td>@(task.Project?.Name ?? "—")</td>
                    <td>
                        <span class="badge @task.Status.ToBadgeClass()">@task.Status.ToHebrew()</span>
                        @if (task.Status == Models.TaskStatus.Waiting && !string.IsNullOrEmpty(task.WaitingReason))
                        {
                            <div class="waiting-reason"><span class="icon icon-clock"></span> @task.WaitingReason</div>
                        }
                    </td>
                    <td><span class="badge @task.Priority.ToBadgeClass()">@task.Priority.ToHebrew()</span></td>
                    <td>@(task.Assignee?.FullName ?? "לא משויך")</td>
                    <td>@(task.DueDate?.ToString("dd/MM/yyyy") ?? "—")</td>
                    <td>
                        <div class="task-actions">
                            @if (task.Status == Models.TaskStatus.InProgress && (task.AssigneeId == AppState.CurrentUser?.Id || AppState.IsAdmin))
                            {
                                <button class="btn btn-sm btn-warning-outline" @onclick="() => ShowWaitingModal(task)" title="העבר להמתנה">
                                    <span class="icon icon-clock"></span> המתנה
                                </button>
                            }
                            @if (task.Status == Models.TaskStatus.Waiting && (task.AssigneeId == AppState.CurrentUser?.Id || AppState.IsAdmin))
                            {
                                <button class="btn btn-sm btn-primary" @onclick="() => ResumeTask(task.Id)" title="חזור לטיפול">
                                    <span class="icon icon-refresh"></span> חזור לטיפול
                                </button>
                            }
                            @if (task.AssigneeId == AppState.CurrentUser?.Id || AppState.IsAdmin)
                            {
                                <button class="btn btn-sm btn-done" @onclick="() => MarkDone(task.Id)" title="סמן כבוצע">
                                    <span class="icon icon-check"></span> בוצע
                                </button>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="empty-state">
        <p>לא נמצאו משימות פעילות.</p>
        <a href="/tasks/create" class="btn btn-primary">צור משימה חדשה</a>
    </div>
}

@if (showWaitingModal)
{
    <div class="modal-overlay" @onclick="CloseWaitingModal">
        <div class="modal-card" @onclick:stopPropagation="true">
            <h2><span class="icon icon-clock"></span> העברה להמתנה</h2>
            <p style="color: var(--text-secondary); margin-bottom: 16px;">
                משימה: <strong>@waitingTask?.Title</strong>
            </p>

            @if (!string.IsNullOrEmpty(waitingError))
            {
                <div class="alert alert-error">@waitingError</div>
            }

            <div class="form-group">
                <label>סיבת ההמתנה *</label>
                <textarea @bind="waitingReason" class="form-control" rows="3"
                          placeholder="לדוגמא: מחכים לקניית שרת, ממתינים לאישור לקוח..."></textarea>
            </div>

            <div class="modal-actions">
                <button class="btn btn-primary" @onclick="ConfirmWaiting">העבר להמתנה</button>
                <button class="btn btn-secondary" @onclick="CloseWaitingModal">ביטול</button>
            </div>
        </div>
    </div>
}

@code {
    private List<TaskItem> tasks = new();
    private List<TaskItem> myNewTasks = new();
    private List<User> users = new();
    private List<Project> projects = new();
    private List<Label> allLabels = new();
    private TaskFilter filter = new();

    private string filterStatus = "";
    private string filterPriority = "";
    private string filterAssignee = "";
    private string filterCreator = "";
    private string filterProject = "";
    private string filterLabel = "";

    // Waiting modal
    private bool showWaitingModal;
    private TaskItem? waitingTask;
    private string waitingReason = "";
    private string waitingError = "";

    protected override async Task OnInitializedAsync()
    {
        if (!AppState.IsLoggedIn) { Nav.NavigateTo("/login"); return; }
        users = await AuthService.GetAllUsersAsync();
        projects = await ProjectService.GetAllProjectsAsync();
        allLabels = await LabelService.GetAllLabelsAsync();
        filter.ExcludeDone = true;
        await LoadTasks();
        await LoadMyNewTasks();
    }

    private async Task LoadTasks()
    {
        filter.Status = string.IsNullOrEmpty(filterStatus) ? null : Enum.Parse<Models.TaskStatus>(filterStatus);
        filter.Priority = string.IsNullOrEmpty(filterPriority) ? null : Enum.Parse<TaskPriority>(filterPriority);
        filter.AssigneeId = string.IsNullOrEmpty(filterAssignee) ? null : int.Parse(filterAssignee);
        filter.CreatorId = string.IsNullOrEmpty(filterCreator) ? null : int.Parse(filterCreator);
        filter.ProjectId = string.IsNullOrEmpty(filterProject) ? null : int.Parse(filterProject);
        filter.ExcludeDone = true;
        tasks = await TaskService.GetTasksAsync(filter);
        ApplyLabelFilter();
    }

    private void ApplyLabelFilter()
    {
        if (!string.IsNullOrEmpty(filterLabel))
        {
            var labelId = int.Parse(filterLabel);
            tasks = tasks.Where(t => t.TaskLabels.Any(tl => tl.LabelId == labelId)).ToList();
        }
    }

    private async Task LoadMyNewTasks()
    {
        myNewTasks = await TaskService.GetTasksAsync(new TaskFilter
        {
            AssigneeId = AppState.CurrentUser!.Id,
            Status = Models.TaskStatus.New
        });
    }

    private async Task TakeTask(int taskId)
    {
        var task = myNewTasks.FirstOrDefault(t => t.Id == taskId);
        if (task == null) return;

        task.Status = Models.TaskStatus.InProgress;
        await TaskService.UpdateTaskAsync(task, AppState.CurrentUser?.Id);
        await LoadTasks();
        await LoadMyNewTasks();
        AppState.ShowToast("המשימה הועברה לטיפול שלך");
        AppState.NotifyStateChanged();
    }

    private void ShowWaitingModal(TaskItem task)
    {
        waitingTask = task;
        waitingReason = "";
        waitingError = "";
        showWaitingModal = true;
    }

    private void CloseWaitingModal()
    {
        showWaitingModal = false;
        waitingTask = null;
        waitingReason = "";
        waitingError = "";
    }

    private async Task ConfirmWaiting()
    {
        if (string.IsNullOrWhiteSpace(waitingReason))
        {
            waitingError = "חובה לרשום סיבת המתנה";
            return;
        }

        if (waitingTask == null) return;

        waitingTask.Status = Models.TaskStatus.Waiting;
        waitingTask.WaitingReason = waitingReason.Trim();
        await TaskService.UpdateTaskAsync(waitingTask);

        CloseWaitingModal();
        await LoadTasks();
        await LoadMyNewTasks();
        AppState.ShowToast("המשימה הועברה להמתנה");
        AppState.NotifyStateChanged();
    }

    private async Task ResumeTask(int taskId)
    {
        var task = tasks.FirstOrDefault(t => t.Id == taskId);
        if (task == null) return;

        task.Status = Models.TaskStatus.InProgress;
        task.WaitingReason = null;
        await TaskService.UpdateTaskAsync(task, AppState.CurrentUser?.Id);
        await LoadTasks();
        AppState.ShowToast("המשימה חזרה לטיפול");
        AppState.NotifyStateChanged();
    }

    private async Task MarkDone(int taskId)
    {
        await TaskService.MarkAsDoneAsync(taskId, AppState.CurrentUser?.Id);
        await LoadTasks();
        await LoadMyNewTasks();
        AppState.ShowToast("המשימה סומנה כבוצעה");
        AppState.NotifyStateChanged();
    }

    private async Task ClearFilters()
    {
        filter = new TaskFilter { ExcludeDone = true };
        filterStatus = "";
        filterPriority = "";
        filterAssignee = "";
        filterCreator = "";
        filterProject = "";
        filterLabel = "";
        await LoadTasks();
    }

    private void GoToTask(int id) => Nav.NavigateTo($"/tasks/{id}");
}
