@page "/login"
@inject AuthService AuthService
@inject AppState AppState
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="auth-card">
    <img src="images/logo.svg" alt="DIGITALCRAFT" class="auth-logo" />
    <h2>כניסה למערכת</h2>
    <p class="auth-subtitle">מערכת CRM לניהול משימות</p>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-error">@errorMessage</div>
    }

    <EditForm Model="loginModel" OnValidSubmit="HandleLogin" FormName="login">
        <div class="form-group">
            <label>שם משתמש (לכניסה)</label>
            <InputText @bind-Value="loginModel.Username" class="form-control" placeholder="הכנס שם משתמש לכניסה" />
        </div>
        <div class="form-group">
            <label>סיסמה</label>
            <div class="input-password-wrap">
                <InputText @bind-Value="loginModel.Password" type="@(showPassword ? "text" : "password")" class="form-control" placeholder="הכנס סיסמה" />
                <button type="button" class="btn-eye" @onclick="() => showPassword = !showPassword" tabindex="-1">
                    @if (showPassword)
                    {
                        <span class="icon icon-eye-off"></span>
                    }
                    else
                    {
                        <span class="icon icon-eye"></span>
                    }
                </button>
            </div>
        </div>
        <button type="submit" class="btn btn-primary btn-block" disabled="@isLoading">
            @(isLoading ? "מתחבר..." : "כניסה")
        </button>
    </EditForm>

    <p class="auth-link">
        אין לך חשבון? <a href="/register">הרשמה</a>
    </p>
</div>

@code {
    private LoginModel loginModel = new();
    private string errorMessage = string.Empty;
    private bool isLoading;
    private bool showPassword;

    protected override void OnInitialized()
    {
        if (AppState.IsLoggedIn)
            Nav.NavigateTo("/");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await JS.InvokeVoidAsync("initWireAnimation"); } catch { }

            if (!AppState.IsLoggedIn)
            {
                try
                {
                    var savedId = await JS.InvokeAsync<string>("getSession");
                    if (!string.IsNullOrEmpty(savedId) && int.TryParse(savedId, out var userId))
                    {
                        var user = await AuthService.GetUserByIdAsync(userId);
                        if (user != null && user.IsActive && user.IsApproved)
                        {
                            AppState.Login(user);
                            Nav.NavigateTo("/");
                        }
                    }
                }
                catch { }
            }
        }
    }

    private async Task HandleLogin()
    {
        errorMessage = string.Empty;
        isLoading = true;

        if (string.IsNullOrWhiteSpace(loginModel.Username) || string.IsNullOrWhiteSpace(loginModel.Password))
        {
            errorMessage = "יש למלא שם משתמש וסיסמה";
            isLoading = false;
            return;
        }

        // Check if account is locked
        var (isLocked, minutesLeft) = AuthService.IsAccountLocked(loginModel.Username);
        if (isLocked)
        {
            errorMessage = $"החשבון נעול עקב ניסיונות כושלים. נסה שוב בעוד {minutesLeft} דקות.";
            isLoading = false;
            return;
        }

        var user = await AuthService.LoginAsync(loginModel.Username, loginModel.Password);
        if (user != null)
        {
            AppState.Login(user);
            try { await JS.InvokeVoidAsync("saveSession", user.Id); } catch { }
            Nav.NavigateTo("/");
        }
        else
        {
            if (await AuthService.IsUserPendingApproval(loginModel.Username))
                errorMessage = "החשבון שלך ממתין לאישור מנהל. נסה שוב מאוחר יותר.";
            else
                errorMessage = "שם משתמש או סיסמה שגויים";
        }

        isLoading = false;
    }

    private class LoginModel
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
